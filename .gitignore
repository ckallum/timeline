# ignore everything inside wiki/ and .raw/ …
wiki/*
.raw/*
wiki/**/*
.raw/**/*

# …except the top-level READMEs that document the folders
!wiki/README.md
!.raw/README.md

# fully ignore personal capture folders (root-anchored)
/journal/
/inbox/
/reminders/
/_attachments/

# build outputs
timeline/data/
timeline/dist/
timeline/node_modules/
timeline/public/decks/

# local config with potential secrets
.claude/autoingest.config.json

# Obsidian vault metadata
.obsidian/*
!.obsidian/snippets/
!.obsidian/plugins/
!.obsidian/app.json
!.obsidian/appearance.json
!.obsidian/graph.json
.obsidian/plugins/*/data.json
# Excalidraw main.js is 8MB — download via setup script if needed
.obsidian/plugins/obsidian-excalidraw-plugin/main.js

# TypeScript build artifacts
timeline/tsconfig.tsbuildinfo

# standard noise
.DS_Store
*.log
node_modules/

# calsuite (personal harness) — never commit
.claude/settings.local.json

# QMD server + hook logs (written by scripts/serve-timeline.sh and PostToolUse hook)
.claude/logs/
